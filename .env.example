# Metabase instance URL (no trailing slash)
METABASE_INSTANCE_URL=http://localhost:3000

# JWT shared secret — must match the value configured in
# Metabase admin settings (Admin > Settings > Authentication > JWT)
METABASE_JWT_SHARED_SECRET=

# Email address used for JWT authentication — must match an existing Metabase user
METABASE_USER_EMAIL=analyst@example.com

# Anthropic API key
ANTHROPIC_API_KEY=

# Server port (default: 3001)
SERVER_PORT=3001

# Client dev-server port (default: 3100)
CLIENT_PORT=3100
