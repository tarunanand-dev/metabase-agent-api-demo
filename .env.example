# Analytics instance URL (no trailing slash). Used by the server for the Agent API and
# returned to the browser at runtime via GET /api/config (embed.js + Metabase browser).
METABASE_INSTANCE_URL=http://localhost:3000

# JWT shared secret — must match the value configured in
# admin settings (Admin > Settings > Authentication > JWT)
METABASE_JWT_SHARED_SECRET=

# Email address used for JWT authentication — must match an existing user on the instance
METABASE_USER_EMAIL=analyst@example.com

# Anthropic API key
ANTHROPIC_API_KEY=

# Server port (default: 4011)
SERVER_PORT=4011

# Vite dev-server port — UI only; proxies /api to SERVER_PORT (default: 4010)
CLIENT_PORT=4010

# Docker Compose: host port mapped to nginx (container listens on LISTEN_PORT, default 4010).
WEB_PORT=4010
LISTEN_PORT=4010
